# Trading mode: "paper" (testnet) or "live" (mainnet real money)
TRADING_MODE=paper

# Binance Testnet API (for paper mode)
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret

# Binance Mainnet API (for live mode — only enable futures trading, NO withdrawal permission)
BINANCE_LIVE_API_KEY=your_live_api_key
BINANCE_LIVE_API_SECRET=your_live_api_secret

# Telegram (set TELEGRAM_ENABLED=true to enable)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Bark (set BARK_ENABLED=true to enable, multiple URLs separated by comma)
BARK_ENABLED=false
BARK_URLS=https://api.day.app/key1,https://api.day.app/key2
