# Trading mode: "paper" (testnet) or "live" (mainnet real money)
TRADING_MODE=paper

# Binance Testnet API (for paper mode)
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret

# Binance Mainnet API (for live mode — only enable futures trading, NO withdrawal permission)
BINANCE_LIVE_API_KEY=your_live_api_key
BINANCE_LIVE_API_SECRET=your_live_api_secret

# --- Notification channels ---
# Live mode uses Bark; Paper mode uses PushDeer + Telegram

# Telegram (paper mode)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# PushDeer (paper mode, multiple keys separated by comma)
PUSHDEER_ENABLED=false
PUSHDEER_KEYS=your_pushdeer_key1,your_pushdeer_key2

# Bark (live mode, multiple URLs separated by comma)
BARK_ENABLED=false
BARK_URLS=https://api.day.app/key1,https://api.day.app/key2

# Optional: 1m kline historical DB (used by backtesting/compare_trend_timeframe_db.py)
KLINE_DB_HOST=
KLINE_DB_PORT=3306
KLINE_DB_USER=
KLINE_DB_PASSWORD=
KLINE_DB_NAME=crypto_1m
